    "webp",
    "version_info.txt",
    "index.js",
    "gulp-concat-source.js",
    "gulp-ts-sort-declaration.js",
    "ast-dependencies-parse.js",
    "reserved.js",
    "types.js",
    "monkey-path.js",
    "rollup-rename-plugin.js"
  ],
