{
  "name": "game-lib",
  "version": "2.0.7",
  "description": "",
  "main": "index.js",
  "scripts": {
    "pack-install": "for /f %i in ('dir /b *.tgz') do npm install -g %i",
    "buildOnDel": "npm run pack-install && del *.tgz",
    "pack": "node packNpmLib.js packResources && npm pack",
    "build-with-pack": "npm run pack && npm run pack-install && node packNpmLib.js removeTemp",
    "build": "npm run build-with-pack"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/bogegit/TypeScriptLib.git"
  },
  "keywords": [
    "webp",
    "webpconverter",
    "webp-converter",
    "cwebp",
    "dwebp",
    "gif2webp",
    "webpmux"
  ],
  "files": [
    "bin",
    "assets",
    "dist",
    "webp",
    "version_info.txt",
    "index.js",

    "gulp-ifelse.js",
    "gulp-concat-source.js",
    "gulp-ts-sort-declaration.js",
    "gulp-stream-util.js",
    "gulp-namespace.js",

    "typescript-parse.js",
    "ast-dependencies-parse.js",
    "reserved.js",
    "types.js",
    "monkey-path.js",

    "rollup-plugin-rename.js",
    "rollup-plugin-generics.js"
  ]
}
