{
  "name": "@boge-mvp/game-lib",
  "version": "2.0.7",
  "description": "TypeScript Library for LayaAir",
  "main": "index.js",
  "engines": {
    "node": ">=14.16.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "clean": "node packNpmLib.js removeTemp",
    "build:tscore": "gulp --gulpfile TSCore/gulpfile.js",
    "build:gamelib": "gulp --gulpfile GameLib/gulpfile.js",
    "build": "npm run clean && npm run build:tscore && npm run build:gamelib && node packNpmLib.js packResources",
    "pack": "npm run build && npm pack",
    "test-install": "for /f %i in ('dir /b *.tgz') do npm install -g %i"
  },
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/boge-mvp/TypeScriptLib.git"
  },
  "keywords": [
    "webp",
    "laya",
    "typescript",
    "game-lib"
  ],
  "files": [
    "bin",
    "assets",
    "dist",
    "webp",
    "version_info.txt",
    "index.js",
    "index.d.ts",
    "gulp-ifelse.js",
    "gulp-concat-source.js",
    "gulp-ts-sort-declaration.js",
    "gulp-stream-util.js",
    "gulp-namespace.js",
    "typescript-parse.js",
    "ast-dependencies-parse.js",
    "reserved.js",
    "types.js",
    "monkey-path.js",
    "rollup-plugin-rename.js",
    "rollup-plugin-decorators.js",
    "rollup-plugin-generics.js"
  ],
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/fs-extra": "^11.0.4",
    "@types/gulp": "^4.0.18",
    "@types/gulp-rename": "^2.0.4",
    "@types/gulp-sourcemaps": "^0.0.38",
    "@types/node": "^14.18.63",
    "@types/through2": "^2.0.41",
    "concat-with-sourcemaps": "^1.1.0",
    "del": "^5.1.0",
    "fs-extra": "^11.3.2",
    "gulp": "^5.0.1",
    "gulp-rename": "^2.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-terser": "^2.1.0",
    "gulp-typescript": "^6.0.0-alpha.1",
    "gulplog": "^2.2.0",
    "rollup": "^4.46.2",
    "rollup-plugin-glsl": "^1.3.0",
    "terser": "^5.43.1",
    "through2": "^4.0.2",
    "tslib": "^2.8.1",
    "chalk": "^4.1.2",
    "typescript": "^5.9.2",
    "vinyl": "^3.0.1",
    "vinyl-buffer": "^1.0.1",
    "vinyl-fs": "^4.0.2",
    "vinyl-source-stream": "^2.0.0"
  }
}
