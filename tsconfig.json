{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "declaration": true, // 生成 .d.ts 定义文件
    "removeComments": false, // 去除注释
    "noEmitHelpers": true,// 不在输出文件中生成帮助
    "sourceMap": true,
    "skipLibCheck": true, // 跳过类型检查所有 .d.ts 文件。
    "noImplicitOverride": true, // 重写必须添加override
    "stripInternal": true, // 禁用发出在其 JSDoc 注释中包含“@internal”的声明。
    "lib": ["DOM", "ES2017"]
  },
  "exclude": [
    "dist",
    "bin"
  ]
}