{
  "compilerOptions": {
    // 编译后的 JavaScript 代码的目标版本
    "target": "ES6",
    //  编译后的模块系统
    "module": "ES6",
    "baseUrl": ".",
    // 生成 .d.ts 定义文件
    "declaration": true,
    // 去除注释
    "removeComments": false,
    // 不在输出文件中生成帮助
    "noEmitHelpers": true,
    "sourceMap": true,
    // 跳过类型检查所有 .d.ts 文件。
    "skipLibCheck": true,
    // 重写必须添加override
    "noImplicitOverride": true,
    // 禁用完整类型检查
//    "noCheck": true,
    // 禁用发出在其 JSDoc 注释中包含“@internal”的声明。
    "stripInternal": true,
    "experimentalDecorators": true, //  启用装饰器支持。
    "emitDecoratorMetadata": true, //  输出针对装饰器的额外元数据。
    "typeRoots": [
      "./libs",
      "node_modules/@types"
    ],
    // 编译器可用的类型定义和内置对象
    "lib": [
      "DOM",
      "ESNext"
    ]
  },
  "exclude": [
    "dist",
    "bin",
    "GameLib",
    "TSCore",
    "game-lib",
    "index.d.ts"
  ]
}